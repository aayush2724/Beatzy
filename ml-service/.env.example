PORT=8000

# Storage — local dev uses MinIO; production uses Cloudflare R2 (or any S3-compatible API)
# Local:  AWS_S3_ENDPOINT=http://localhost:9000  + minioadmin/minioadmin
# R2:     AWS_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com  + R2 access keys
#         AWS_REGION=auto  (R2); us-east-1 for AWS S3
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=beatzy-audio
# AWS_S3_ENDPOINT=http://localhost:9000
ACOUSTID_API_KEY=your_acoustid_api_key
# Production (Hugging Face Spaces): set ACOUSTID_API_KEY, SPOTIFY_CLIENT_ID, SPOTIFY_CLIENT_SECRET in Space secrets
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
