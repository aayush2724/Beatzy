# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://beatzy:beatzy_secret@localhost:5432/beatzy

# Redis
REDIS_URL=redis://:redis_secret@localhost:6379

# JWT
JWT_SECRET=change_me_in_production_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage — local dev: MinIO (docker-compose). Production: Cloudflare R2 or AWS S3.
# Local:  AWS_S3_ENDPOINT=http://localhost:9000  credentials minioadmin/minioadmin
# R2:     AWS_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com  AWS_REGION=auto
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=beatzy-audio
# AWS_S3_ENDPOINT=http://localhost:9000

# AcoustID (song fingerprinting — set on ML service / Hugging Face)
ACOUSTID_API_KEY=your_acoustid_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ML Service
ML_SERVICE_URL=http://localhost:8000
# Production: ML_SERVICE_URL=https://aayush-27-beatzy-ml.hf.space

# Frontend (CORS allow-list)
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://beatzy-zeta.vercel.app
