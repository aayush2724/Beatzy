modules = ["nodejs-20", "python-3.12", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ML Service"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm start"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "ML Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ml-service && uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
BACKEND_URL = "https://8469904e-6f3f-47ea-b7ca-26fcef385527-00-148riespnxzhd.sisko.replit.dev"
FRONTEND_URL = "https://8469904e-6f3f-47ea-b7ca-26fcef385527-00-148riespnxzhd.sisko.replit.dev"
NODE_ENV = "development"
PORT = "3000"
ML_SERVICE_URL = "http://localhost:8000"
CORS_ORIGIN = "https://8469904e-6f3f-47ea-b7ca-26fcef385527-00-148riespnxzhd.sisko.replit.dev"
